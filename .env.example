# OptionPlay Environment Configuration
# =====================================
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git!

# Marketdata.app API Key
# Get yours at: https://www.marketdata.app/
MARKETDATA_API_KEY=your_api_key_here

# Tradier API (optional)
TRADIER_API_KEY=
TRADIER_SANDBOX=true

# IBKR Settings (optional)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
